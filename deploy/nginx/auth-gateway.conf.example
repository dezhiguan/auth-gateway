upstream auth_gateway_backend {
    server 172.25.90.184:31091 max_fails=3 fail_timeout=30s;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name auth.careermate.cn;

    ssl_certificate /etc/nginx/ssl/auth.careermate.cn/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/auth.careermate.cn/privkey.pem;

    location / {
        proxy_pass http://auth_gateway_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host auth.careermate.cn;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 5s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}

server {
    listen 80;
    server_name auth.careermate.cn;

    location / {
        proxy_pass http://auth_gateway_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host auth.careermate.cn;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
        proxy_connect_timeout 5s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
